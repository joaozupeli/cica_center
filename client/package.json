    "@tiig/moeda": "^1.0.14",
    "@tiig/v-uppercase": "^1.0.9",
    "@vueuse/core": "^10.11.0",
    "apexcharts": "^5.3.6",
    "axios": "^1.7.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "maska": "^3.0.0",
    "pinia": "^2.1.7",
    "socket.io-client": "^4.8.0",
    "sortablejs": "^1.15.3",
    "vue": "^3.4.29",
    "vue-router": "^4.3.3",
    "vue-toastification": "^2.0.0-rc.5",
