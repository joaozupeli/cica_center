{
  "name": "igcampanhas-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint src/**/*.{ts,js,vue} --fix --format codeframe",
    "format": "prettier --write src/",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf yarn.lock && yarn"
  },
  "dependencies": {
